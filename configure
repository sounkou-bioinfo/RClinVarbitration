#!/bin/sh
set -eu

ROOT=`CDPATH= cd -- "$(dirname -- "$0")" && pwd`
HOST_TRIPLET=""
for arg in "$@"; do
  case "$arg" in
    --host=*) HOST_TRIPLET="${arg#--host=}" ;;
  esac
done

if [ -z "${R_HOME:-}" ]; then
  R_HOME=`R RHOME`
fi

OS=`uname -s`
ARCH=`uname -m`
WINDOWS_BUILD=no
case "$OS" in
  MINGW*|MSYS*|CYGWIN*) WINDOWS_BUILD=yes ;;
esac

VERSION=`awk -F': *' '/^Version:/ {print $2; exit}' "$ROOT/DESCRIPTION"`
CAPI_ROOT="$ROOT/tools/ext/duckdb_capi"
VERSIONS_FILE="$CAPI_ROOT/versions.txt"
SOURCE="$ROOT/tools/ext/rclinvarbitration_extension.c"
METADATA="$ROOT/tools/append_extension_metadata.R"
BUILD_ROOT="$ROOT/inst/rclinvarbitration_extension/build"

for file in "$VERSIONS_FILE" "$SOURCE" "$METADATA"; do
  if [ ! -f "$file" ]; then
    echo "ERROR: required native extension file is missing: $file" >&2
    exit 1
  fi
done

PKG_CONFIG_CMD="${PKG_CONFIG:-pkg-config}"
if [ "$WINDOWS_BUILD" = yes ]; then
  # Rtools ships target-aware pkg-config wrappers and static libxml2/zlib.
  # Respect BINPREF when R is configured for an explicit cross-tool prefix.
  BINPREF=`"${R_HOME}/bin/R" CMD config BINPREF 2>/dev/null || true`
  if [ -n "$BINPREF" ] && command -v "${BINPREF}pkg-config" >/dev/null 2>&1; then
    PKG_CONFIG_CMD="${BINPREF}pkg-config"
  fi
fi
if ! command -v "$PKG_CONFIG_CMD" >/dev/null 2>&1 || \
  ! "$PKG_CONFIG_CMD" --exists libxml-2.0 || \
  ! "$PKG_CONFIG_CMD" --exists zlib; then
  echo "ERROR: RClinVarbitration requires libxml2 and zlib development headers plus pkg-config" >&2
  if [ "$WINDOWS_BUILD" = yes ]; then
    echo "Install a current Rtools release, which provides all three dependencies." >&2
  fi
  exit 1
fi

SUPPORTED=`sed -e 's/[[:space:]]*#.*$//' -e '/^[[:space:]]*$/d' "$VERSIONS_FILE"`
BUILD_VERSIONS="${RCLINVAR_DUCKDB_VERSIONS:-$SUPPORTED}"
if [ -z "$BUILD_VERSIONS" ]; then
  echo "ERROR: no DuckDB versions selected" >&2
  exit 1
fi
for version in $BUILD_VERSIONS; do
  if ! printf '%s\n' "$version" | grep -Eq '^v[0-9]+\.[0-9]+\.[0-9]+$' || \
    ! printf '%s\n' "$SUPPORTED" | grep -Fqx "$version"; then
    echo "ERROR: DuckDB version '$version' is not declared in $VERSIONS_FILE" >&2
    exit 1
  fi
  if [ ! -f "$CAPI_ROOT/$version/duckdb.h" ] || \
    [ ! -f "$CAPI_ROOT/$version/duckdb_extension.h" ] || \
    [ ! -f "$CAPI_ROOT/$version/duckdb_headers.json" ]; then
    echo "ERROR: incomplete DuckDB C API headers for $version" >&2
    exit 1
  fi
  pinned=`awk -F'"' '/"duckdb_ref"/ {print $4; exit}' "$CAPI_ROOT/$version/duckdb_headers.json"`
  if [ "$pinned" != "$version" ]; then
    echo "ERROR: $CAPI_ROOT/$version metadata records '$pinned', expected '$version'" >&2
    exit 1
  fi
done

CC=`"${R_HOME}/bin/R" CMD config CC | cut -f1 -d' '`
R_CFLAGS=`"${R_HOME}/bin/R" CMD config CFLAGS`
R_CPICFLAGS=`"${R_HOME}/bin/R" CMD config CPICFLAGS`
R_LDFLAGS=`"${R_HOME}/bin/R" CMD config LDFLAGS`
CONFIGURE_LDFLAGS="${LDFLAGS:-}"
XML_CFLAGS=`"$PKG_CONFIG_CMD" --cflags libxml-2.0`
XML_LIBS=`"$PKG_CONFIG_CMD" --libs libxml-2.0`
ZLIB_CFLAGS=`"$PKG_CONFIG_CMD" --cflags zlib`
ZLIB_LIBS=`"$PKG_CONFIG_CMD" --libs zlib`

WASM_BUILD=no
if echo "$CC" | grep -q 'emcc\|wasm' || echo "$HOST_TRIPLET" | grep -q 'wasm\|emscripten'; then
  WASM_BUILD=yes
fi

if [ "$WASM_BUILD" = yes ]; then
  # DuckDB's webR/duckdb-wasm loader accepts Emscripten side modules under
  # this platform identity, matching the Rducks extension contract.
  PLATFORMS=linux_i686_musl
  SHARED_FLAGS='-shared -fPIC'
  EXTRA_CFLAGS=''
  EXT_EXPORT_FLAGS='-Wl,--export=rclinvarbitration_init_c_api'
else
  EXT_EXPORT_FLAGS=''
  case "$OS/$ARCH" in
    Linux/x86_64) PLATFORMS=linux_amd64; SHARED_FLAGS='-shared -fPIC -Wl,--exclude-libs,ALL -Wl,-Bsymbolic-functions'; EXTRA_CFLAGS='' ;;
    Linux/aarch64|Linux/arm64) PLATFORMS=linux_arm64; SHARED_FLAGS='-shared -fPIC -Wl,--exclude-libs,ALL -Wl,-Bsymbolic-functions'; EXTRA_CFLAGS='' ;;
    # DuckDB's exact v1.5 headers retain legacy empty-prototype declarations.
    # Keep -Werror for package code while preventing current Apple Clang from
    # rejecting that vendored-header-only diagnostic.
    Darwin/x86_64) PLATFORMS=osx_amd64; SHARED_FLAGS='-shared -fPIC -undefined dynamic_lookup -Wl,-exported_symbol,_rclinvarbitration_init_c_api'; EXTRA_CFLAGS='-Wno-error=strict-prototypes' ;;
    Darwin/arm64) PLATFORMS=osx_arm64; SHARED_FLAGS='-shared -fPIC -undefined dynamic_lookup -Wl,-exported_symbol,_rclinvarbitration_init_c_api'; EXTRA_CFLAGS='-Wno-error=strict-prototypes' ;;
    # CRAN release builds currently report windows_amd64 while R-devel's
    # MinGW toolchain reports windows_amd64_mingw. The machine code is the
    # same, but DuckDB validates the embedded platform metadata exactly.
    MINGW*/x86_64|MSYS*/x86_64|CYGWIN*/x86_64) PLATFORMS='windows_amd64 windows_amd64_mingw'; SHARED_FLAGS='-shared'; EXTRA_CFLAGS='' ;;
    *) echo "ERROR: unsupported DuckDB extension platform: $OS/$ARCH" >&2; exit 1 ;;
  esac
fi

rm -rf "$BUILD_ROOT"
mkdir -p "$BUILD_ROOT"
if [ "$WASM_BUILD" = yes ]; then
  # A side module exports only explicitly listed symbols. Do not pass host R
  # linker flags or native symbol-hiding flags into the Emscripten link.
  CFLAGS="$R_CFLAGS $R_CPICFLAGS -O2 -fPIC $EXTRA_CFLAGS"
else
  CFLAGS="$R_CFLAGS $R_CPICFLAGS -O2 -fPIC -fvisibility=hidden -Wall -Wextra -Werror $EXTRA_CFLAGS"
fi

for DUCKDB_VERSION in $BUILD_VERSIONS; do
  HEADER_DIR="$CAPI_ROOT/$DUCKDB_VERSION"
  OUT_DIR="$BUILD_ROOT/$DUCKDB_VERSION"
  RAW="$OUT_DIR/rclinvarbitration.duckdb_extension.raw"
  CPPFLAGS="-DNDEBUG -DDUCKDB_EXTENSION_NAME=rclinvarbitration -DDUCKDB_EXTENSION_API_VERSION_UNSTABLE=$DUCKDB_VERSION -DDUCKDB_EXTENSION_API_UNSTABLE_VERSION=\"$DUCKDB_VERSION\" -I$HEADER_DIR $XML_CFLAGS $ZLIB_CFLAGS"
  mkdir -p "$OUT_DIR"

  echo "Building RClinVarbitration extension for DuckDB $DUCKDB_VERSION..."
  "$CC" $SHARED_FLAGS $CFLAGS $CPPFLAGS $R_LDFLAGS $CONFIGURE_LDFLAGS \
    -o "$RAW" $EXT_EXPORT_FLAGS "$SOURCE" $XML_LIBS $ZLIB_LIBS
  for METADATA_PLATFORM in $PLATFORMS; do
    PLATFORM_DIR="$OUT_DIR/$METADATA_PLATFORM"
    FINAL="$PLATFORM_DIR/rclinvarbitration.duckdb_extension"
    mkdir -p "$PLATFORM_DIR"
    "${R_HOME}/bin/Rscript" "$METADATA" \
      --library-file "$RAW" \
      --out-file "$FINAL" \
      --extension-name rclinvarbitration \
      --duckdb-platform "$METADATA_PLATFORM" \
      --duckdb-version "$DUCKDB_VERSION" \
      --extension-version "$VERSION" \
      --abi-type C_STRUCT_UNSTABLE
  done
  rm -f "$RAW"
done

echo "Built RClinVarbitration artifacts for: $BUILD_VERSIONS"
